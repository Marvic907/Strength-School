{
  "expo": {
    "name": "Strength School Onboarding",
    "slug": "strength-school-onboarding",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "mt.strengthschool.onboarding"
    },
    "android": {
      "package": "mt.strengthschool.onboarding"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "brandLogoPath": "assets/branding/README.md"
    },
    "experiments": {
      "baseUrl": "/Strength-School"
    }
  }
}
